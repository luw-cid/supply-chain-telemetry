                  "const chain = pm.response.json().data.chain;",
                  "pm.test('Tất cả bước trừ cuối: TRANSFERRED + endAtUTC ≠ null', () => {",
                  "  for (let i = 0; i < chain.length - 1; i++) {",
                  "    pm.expect(chain[i].ownershipStatus).to.equal('TRANSFERRED', `Bước ${i+1} phải TRANSFERRED`);",
                  "    pm.expect(chain[i].endAtUTC).to.not.be.null;",
                  "  }",
                  "});",
                  "pm.test('chainDepth tăng tuần tự từ 1', () => {",
                  "  chain.forEach((step, idx) => pm.expect(step.chainDepth).to.equal(idx + 1));",
                  "});",
                  "pm.test('Chỉ 1 bước ACTIVE', () => {",
                  "  const active = chain.filter(c => c.ownershipStatus === 'ACTIVE');",
                  "  pm.expect(active.length).to.equal(1);",
                  "});",
                  "pm.test('Thứ tự stepNumber tăng dần', () => {",
                  "  for (let i = 1; i < chain.length; i++) {",
                  "    pm.expect(chain[i].stepNumber).to.equal(chain[i-1].stepNumber + 1);",
