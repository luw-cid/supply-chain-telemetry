            },
            {
              "key": "destination",
              "value": "VNSGN"
            }
          ]
        },
        "description": "Test case: Business logic error - same port\n\nExpected Result:\n- Status: 400 Bad Request\n- Error: SAME_PORT\n- Message: Origin and destination cannot be the same"
      },
      "response": []
