      "name": "🔐 AUTH",
      "item": [
        {
          "name": "AUTH — Đăng nhập lấy JWT token",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "if (pm.response.code === 200) {",
                  "  const body = pm.response.json();",
                  "  const token = body?.data?.accessToken;",
                  "  if (token) {",
                  "    pm.collectionVariables.set('token', token);",
                  "    pm.test('✅ Login thành công — token đã lưu', () => pm.expect(token).to.be.a('string'));",
                  "  }",
                  "} else {",
                  "  pm.test('❌ Login thất bại — kiểm tra seed data và JWT_SECRET trong .env', () => pm.expect(pm.response.code).to.equal(200));",
                  "}"
                ],
                "type": "text/javascript"
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"testuser@custody.vn\",\n  \"password\": \"Password@123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": [
                "{{baseUrl}}"
              ],
              "path": [
                "api",
                "auth",
                "login"
              ]
            }
          }
        }
